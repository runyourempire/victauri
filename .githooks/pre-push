#!/bin/bash
# Verax FLEET local pre-push gate (generalized — cargo, node, or mixed repos). Replaces reliance on hosted
# GitHub Actions for private-repo pushes: runs the repo's real gate locally at $0.
#
#   GATE 1 — committed-tree COHERENCE of the tree you are PUSHING (not the working dir), per stack:
#            cargo repos → `cargo metadata`; node repos → package.json parses. Catches the "green locally,
#            garbage in the commit" corruption class (the PR #78 graft). Skipped only if neither manifest exists.
#   GATE 2 — FUNCTIONAL gate: `verax pipeline .verax/gate.json` (skip-cached, bounded-parallel; stack-agnostic).
#
# ENFORCEMENT (the gap this version closes): if the functional gate cannot RUN (no pipeline-capable verax found),
# the default is fail-OPEN with a LOUD notice — but set **VERAX_GATE_REQUIRE=1** to fail-CLOSED (block the push)
# so a missing binary can never silently let an UN-GATED push through. Pick fail-open for convenience, REQUIRE
# for guaranteed enforcement.
#   BYPASS: `git push --no-verify` (git-native) or `VERAX_SKIP_GATE=1`.
set -u
REQUIRE="${VERAX_GATE_REQUIRE:-0}"
[ "${VERAX_SKIP_GATE:-0}" = "1" ] && { echo "[verax-gate] bypassed (VERAX_SKIP_GATE=1)"; exit 0; }
PUSH_REFS="$(cat 2>/dev/null || true)"   # stdin consumable once — capture before anything reads it
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

# ---- GATE 1: committed-tree coherence (stack-aware) ----
have_cargo=0; have_node=0
[ -f "$ROOT/Cargo.toml" ] && have_cargo=1
[ -f "$ROOT/package.json" ] && have_node=1
if { [ $have_cargo = 1 ] || [ $have_node = 1 ]; } && command -v tar >/dev/null 2>&1 && [ -n "$PUSH_REFS" ]; then
  ZERO="0000000000000000000000000000000000000000"
  while read -r lref lsha rref rsha; do
    [ -n "${lsha:-}" ] || continue
    [ "$lsha" = "$ZERO" ] && continue
    work="$(mktemp -d 2>/dev/null)" || continue
    if git archive "$lsha" 2>/dev/null | tar -x -C "$work" 2>/dev/null; then
      ok=1
      if [ $have_cargo = 1 ] && command -v cargo >/dev/null 2>&1; then
        ( cd "$work" && cargo metadata --no-deps --format-version 1 >/dev/null 2>&1 ) || ok=0
      fi
      if [ $ok = 1 ] && [ $have_node = 1 ] && command -v node >/dev/null 2>&1; then
        node -e "JSON.parse(require('fs').readFileSync(process.argv[1],'utf8'))" "$work/package.json" >/dev/null 2>&1 || ok=0
      fi
      if [ $ok = 0 ]; then
        rm -rf "$work"
        echo "[verax-gate] GATE 1 FAIL — committed tree $lsha is NOT coherent (manifest missing/unparseable: the corruption class)."
        echo "[verax-gate]   Inspect: git ls-tree -r $lsha | head   ·   Bypass: git push --no-verify"
        exit 1
      fi
    fi
    rm -rf "$work"
  done <<< "$PUSH_REFS"
  echo "[verax-gate] GATE 1: committed-tree coherence OK"
fi

# ---- GATE 2: functional gate via verax pipeline ----
SPEC="$ROOT/.verax/gate.json"
[ -f "$SPEC" ] || { echo "[verax-gate] no .verax/gate.json — functional gate not configured (push allowed)"; exit 0; }
VERAX=""
for cand in "${VERAX_BIN:-}" "$(command -v verax 2>/dev/null || true)" \
            "/d/dev-cache/.cargo/bin/verax-pipeline.exe" "/d/dev-cache/.cargo/bin/verax.exe" \
            "$ROOT/target/release/verax.exe" "$ROOT/target/debug/verax.exe"; do
  [ -n "$cand" ] || continue
  if "$cand" pipeline --help >/dev/null 2>&1; then VERAX="$cand"; break; fi
done
if [ -z "$VERAX" ]; then
  if [ "$REQUIRE" = "1" ]; then
    echo "[verax-gate] BLOCKED — no pipeline-capable verax found and VERAX_GATE_REQUIRE=1 (strict). The gate could"
    echo "[verax-gate]   not run, so this UN-GATED push is refused. Build/stage verax, or bypass: git push --no-verify"
    exit 1
  fi
  echo "[verax-gate] ⚠ no pipeline-capable verax found — functional gate did NOT run, push allowed (FAIL-OPEN)."
  echo "[verax-gate]   This push was NOT functionally verified. Set VERAX_GATE_REQUIRE=1 to enforce (fail-closed)."
  exit 0
fi
echo "[verax-gate] GATE 2: local functional gate ($VERAX; skip-cached; bypass: git push --no-verify) ..."
if "$VERAX" pipeline --spec "$SPEC" --cwd "$ROOT"; then
  echo "[verax-gate] PASS — push allowed"; exit 0
fi
echo "[verax-gate] FAIL — push BLOCKED. Fix the gate, or bypass with: git push --no-verify"
exit 1
